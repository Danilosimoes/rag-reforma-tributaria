# Chave da API Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Modelo Claude usado para geração das respostas.
# Ver README para justificativa da escolha do modelo.
ANTHROPIC_MODEL=claude-sonnet-5

# Máximo de tokens de saída por resposta do LLM
ANTHROPIC_MAX_TOKENS=2048

# Modelo de embeddings (sentence-transformers, roda local)
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Tamanho e overlap dos chunks de texto (em caracteres)
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Quantidade de chunks recuperados por pergunta
TOP_K=4

# Timeout (segundos) para requisições HTTP ao carregar páginas web
WEB_REQUEST_TIMEOUT_SEGUNDOS=15
